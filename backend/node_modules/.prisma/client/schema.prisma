generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  phone       String
  firebaseUid String   @unique
  role        String   @default("parent")
  children    Child[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model School {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  address   String?
  children  Child[]
  menus     Menu[]
  createdAt DateTime @default(now())
}

model Child {
  id           Int      @id @default(autoincrement())
  name         String
  className    String
  subscriberId String   @unique
  mealBalance  Int      @default(0)
  parentId     Int
  schoolId     Int
  parent       User     @relation(fields: [parentId], references: [id])
  school       School   @relation(fields: [schoolId], references: [id])
  createdAt    DateTime @default(now())
}

model Menu {
  id       Int      @id @default(autoincrement())
  schoolId Int
  title    String   @default("Daily Menu")
  items    String
  imageUrl String
  date     DateTime @default(now())
  school   School   @relation(fields: [schoolId], references: [id])
}
